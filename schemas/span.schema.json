{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Momentum One telemetry span (telemetry/tracer.py)",
  "type": "object",
  "required": ["span_id","name","t0","status"],
  "properties": {
    "span_id": {"type":"string"}, "name": {"type":"string"},
    "parent": {"type":["string","null"]}, "run_id": {"type":["string","null"]},
    "t0": {"type":"number"}, "t1": {"type":"number"}, "ms": {"type":"number"},
    "status": {"enum":["ok","error","event"]}, "error": {"type":"string"},
    "attrs": {"type":"object"}
  }
}
